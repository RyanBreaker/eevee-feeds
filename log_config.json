{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "default": {
      "()": "app.logging_config.SingleLineFormatter",
      "fmt": "%(levelname)s:     %(message)s"
    },
    "access": {
      "()": "app.logging_config.SingleLineFormatter",
      "fmt": "%(levelname)s:     %(message)s"
    }
  },
  "filters": {
    "max_info": {
      "()": "app.log_filter.MaxLevelFilter",
      "max_level": "INFO"
    }
  },
  "handlers": {
    "stdout": {
      "class": "logging.StreamHandler",
      "level": "INFO",
      "formatter": "default",
      "filters": ["max_info"],
      "stream": "ext://sys.stdout"
    },
    "stderr": {
      "class": "logging.StreamHandler",
      "level": "WARNING",
      "formatter": "default",
      "stream": "ext://sys.stderr"
    },
    "access": {
      "class": "logging.StreamHandler",
      "level": "INFO",
      "formatter": "access",
      "stream": "ext://sys.stdout"
    }
  },
  "loggers": {
    "uvicorn": {
      "handlers": ["stdout", "stderr"],
      "level": "INFO"
    },
    "uvicorn.access": {
      "handlers": ["access"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.error": {
      "handlers": ["stdout", "stderr"],
      "level": "INFO",
      "propagate": false
    }
  }
}
